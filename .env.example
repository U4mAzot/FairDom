# Supabase (Authentication) — Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Supabase CLI (migracje na produkcję): npm run supabase:login → npm run supabase:link → npm run supabase:push
# Albo: ustaw SUPABASE_ACCESS_TOKEN (Account → Access Tokens) i uruchom tylko link + push.

# Optional: if your dashboard only shows the new "Publishable" key, you can use:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
